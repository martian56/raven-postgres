import std/env { get_env_or, has_env }
import std/string
import std/test { assert_eq_int, assert_eq_str, assert_msg, assert_true }
import "./lib" { connect, Connection }

fun e2e_enabled() -> Bool {
    return has_env("RAVEN_POSTGRES_E2E")
}

fun postgres_port() -> Int {
    return match get_env_or("RAVEN_POSTGRES_PORT", "55432").parse_int() {
        Some(port) -> port,
        None -> 55432,
    }
}

fun must<T>(result: Result<T, Error>) -> T {
    return match result {
        Ok(value) -> value,
        Err(e) -> {
            __panic(e.message())
            must(result)
        },
    }
}

fun open_test_db() -> Connection {
    return must(
        connect(
            get_env_or("RAVEN_POSTGRES_HOST", "127.0.0.1"),
            postgres_port(),
            get_env_or("RAVEN_POSTGRES_USER", "raven"),
            get_env_or("RAVEN_POSTGRES_PASSWORD", "ravenpw"),
            get_env_or("RAVEN_POSTGRES_DATABASE", "ravendb"),
        ),
    )
}

fun test_e2e_connect_and_server_metadata() {
    if !e2e_enabled() {
        return
    }
    let conn = open_test_db()
    assert_true(conn.server_version.length() > 0)
    assert_true(conn.backend_pid > 0)
    assert_true(must(conn.ping()))
    let result = must(conn.query("SELECT current_database(), pg_backend_pid()"))
    assert_eq_int(result.row_count(), 1)
    assert_eq_str(result.rows[0].get(0), get_env_or("RAVEN_POSTGRES_DATABASE", "ravendb"))
    assert_eq_str(result.rows[0].get(1), "${conn.backend_pid}")
    conn.close()
}

fun test_e2e_create_insert_and_select_rows() {
    if !e2e_enabled() {
        return
    }
    let conn = open_test_db()
    let _ = must(conn.execute("DROP TABLE IF EXISTS raven_postgres_basic"))
    let _ = must(
        conn.execute(
            "CREATE TABLE raven_postgres_basic (id BIGSERIAL PRIMARY KEY, name TEXT NOT NULL, score NUMERIC(8,2))",
        ),
    )
    assert_eq_int(
        must(
            conn.execute(
                "INSERT INTO raven_postgres_basic (name, score) VALUES ('Ada', 9.50), ('Grace', 8.25), ('Linus', 7.00)",
            ),
        ),
        3,
    )
    let result = must(conn.query("SELECT id, name, score FROM raven_postgres_basic ORDER BY id"))
    assert_eq_int(result.row_count(), 3)
    assert_eq_str(result.columns[0], "id")
    assert_eq_str(result.rows[0].get(0), "1")
    assert_eq_str(result.rows[1].get(1), "Grace")
    assert_eq_str(result.rows[2].get(2), "7.00")
    let _ = must(conn.execute("DROP TABLE raven_postgres_basic"))
    conn.close()
}

fun test_e2e_parameters_cannot_change_sql_syntax() {
    if !e2e_enabled() {
        return
    }
    let conn = open_test_db()
    let _ = must(conn.execute("DROP TABLE IF EXISTS raven_postgres_params"))
    let _ = must(conn.execute("CREATE TABLE raven_postgres_params (value TEXT NOT NULL)"))
    let hostile = "O'Brien'); DROP TABLE raven_postgres_params; --"
    assert_eq_int(
        must(conn.execute_params("INSERT INTO raven_postgres_params VALUES ($1)", [hostile])),
        1,
    )
    let result = must(
        conn.query_params("SELECT value FROM raven_postgres_params WHERE value = $1", [hostile]),
    )
    assert_eq_int(result.row_count(), 1)
    assert_eq_str(result.rows[0].get(0), hostile)
    assert_eq_str(
        must(conn.query("SELECT COUNT(*) FROM raven_postgres_params")).rows[0].get(0),
        "1",
    )
    let _ = must(conn.execute("DROP TABLE raven_postgres_params"))
    conn.close()
}

fun test_e2e_null_and_empty_string_remain_distinct() {
    if !e2e_enabled() {
        return
    }
    let conn = open_test_db()
    let _ = must(conn.execute("DROP TABLE IF EXISTS raven_postgres_nulls"))
    let _ = must(
        conn.execute(
            "CREATE TABLE raven_postgres_nulls (nullable_value TEXT NULL, empty_value TEXT NOT NULL)",
        ),
    )
    let params: List<Option<String>> = [None, Some("")]
    assert_eq_int(
        must(
            conn.execute_optional_params(
                "INSERT INTO raven_postgres_nulls (nullable_value, empty_value) VALUES ($1, $2)",
                params,
            ),
        ),
        1,
    )
    let result = must(conn.query("SELECT nullable_value, empty_value FROM raven_postgres_nulls"))
    assert_true(result.rows[0].is_null(0))
    assert_eq_str(result.rows[0].get(0), "")
    assert_true(!result.rows[0].is_null(1))
    assert_eq_str(result.rows[0].get(1), "")
    let _ = must(conn.execute("DROP TABLE raven_postgres_nulls"))
    conn.close()
}

fun test_e2e_connection_recovers_after_sql_error() {
    if !e2e_enabled() {
        return
    }
    let conn = open_test_db()
    match conn.query("SELECT * FROM raven_postgres_table_that_does_not_exist") {
        Ok(result) -> assert_msg(false, "expected missing-table query to fail"),
        Err(e) -> {
            assert_eq_str(e.kind(), "postgres")
            assert_true(e.message().contains("42P01"))
        },
    }
    let result = must(conn.query("SELECT 42 AS answer"))
    assert_eq_str(result.rows[0].get(0), "42")
    conn.close()
}
